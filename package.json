{
  "name": "ferrite.js",
  "version": "1.3.0",
  "description": "Canvas + WASM software/WebCodecs video player — a drop-in for mpegts.js for the no-hardware-HEVC niche.",
  "type": "module",
  "license": "MIT AND LGPL-2.1-or-later",
  "author": "multiduplikator",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/multiduplikator/ferrite.js.git"
  },
  "homepage": "https://gitlab.com/multiduplikator/ferrite.js#readme",
  "bugs": {
    "url": "https://gitlab.com/multiduplikator/ferrite.js/-/issues"
  },
  "keywords": [
    "mpegts",
    "hevc",
    "h265",
    "webcodecs",
    "webassembly",
    "ffmpeg",
    "iptv",
    "video",
    "player",
    "canvas",
    "decoder"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./controls": {
      "types": "./dist/controls.d.ts",
      "import": "./dist/controls.js"
    },
    "./assets/*": "./assets/*"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "assets/ferrite.mjs",
    "assets/ferrite.wasm",
    "README.md",
    "LICENSE",
    "engine/COPYING.LGPLv2.1"
  ],
  "scripts": {
    "build": "tsup",
    "build:debug": "FERRITE_DEBUG=1 tsup",
    "dev": "FERRITE_DEBUG=1 tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo": "npm run build:debug && node demo/serve.mjs",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
